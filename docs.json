{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Postrun",
  "colors": {
    "primary": "#1942F5",
    "light": "#5B79FF",
    "dark": "#1942F5"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Geist"
    }
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/metadata",
      "destination": "/storage"
    },
    {
      "source": "/react",
      "destination": "/react/get-started"
    },
    {
      "source": "/react/reading-and-writing",
      "destination": "/react/fetching-and-mutations"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "storage",
              "authentication",
              "idempotency",
              "rate-limits"
            ]
          },
          {
            "group": "React SDK",
            "pages": [
              "react/get-started",
              "react/fetching-and-mutations"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.postrun.ai/v1/openapi.json"
      },
      {
        "tab": "Errors",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "errors/overview"
            ]
          },
          {
            "group": "Transport errors",
            "pages": [
              "errors/overview",
              "errors/unauthorized",
              "errors/forbidden",
              "errors/not_found",
              "errors/conflict",
              "errors/validation_failed",
              "errors/rate_limited",
              "errors/internal_error",
              "errors/idempotency_key_invalid",
              "errors/idempotency_key_reused",
              "errors/idempotency_request_in_progress",
              "errors/source_url_unsupported",
              "errors/account_not_available",
              "errors/connection_reauth_required",
              "errors/connection_not_pending",
              "errors/not_implemented",
              "errors/media_processing",
              "errors/not_publishable"
            ]
          },
          {
            "group": "Domain verdicts",
            "pages": [
              "errors/overview",
              "errors/media_unprobeable",
              "errors/media_too_large",
              "errors/media_aspect_ratio_unsupported",
              "errors/media_resolution_too_low",
              "errors/media_gif_unsupported",
              "errors/media_format_recompressed",
              "errors/media_resolution_downscaled",
              "errors/video_container_unsupported",
              "errors/video_codec_unsupported",
              "errors/video_audio_codec_unsupported",
              "errors/video_too_large",
              "errors/video_too_small",
              "errors/video_dimensions_unsupported",
              "errors/video_fps_unsupported",
              "errors/video_aspect_unsupported",
              "errors/video_duration_too_short",
              "errors/video_duration_exceeds_max",
              "errors/document_format_unsupported",
              "errors/document_too_large",
              "errors/document_too_many_pages",
              "errors/media_count_invalid",
              "errors/body_too_long",
              "errors/content_missing",
              "errors/content_conflict",
              "errors/content_incomplete",
              "errors/content_kind_mismatch",
              "errors/media_type_mismatch",
              "errors/tag_limit_exceeded",
              "errors/reel_field_on_non_reel",
              "errors/media_not_ready",
              "errors/media_failed",
              "errors/media_unsupported",
              "errors/media_kind_mismatch",
              "errors/publishing_unavailable",
              "errors/x_duplicate_content",
              "errors/x_not_authorized",
              "errors/x_rate_limited",
              "errors/x_publish_failed",
              "errors/x_media_upload_failed",
              "errors/linkedin_duplicate_content",
              "errors/linkedin_auth_expired",
              "errors/linkedin_permission_denied",
              "errors/linkedin_media_processing",
              "errors/linkedin_media_upload_failed",
              "errors/linkedin_publish_failed",
              "errors/instagram_media_processing",
              "errors/instagram_container_expired",
              "errors/instagram_container_failed",
              "errors/instagram_rate_limited",
              "errors/instagram_not_authorized",
              "errors/instagram_publish_failed",
              "errors/facebook_reel_processing",
              "errors/facebook_reel_failed",
              "errors/facebook_rate_limited",
              "errors/facebook_not_authorized",
              "errors/facebook_publish_failed",
              "errors/connection_platform_mismatch"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.postrun.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/postrun_ai",
      "github": "https://github.com/Postrun-ai"
    }
  }
}
