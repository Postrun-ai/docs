{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Postrun",
  "colors": {
    "primary": "#1942F5",
    "light": "#5B79FF",
    "dark": "#1942F5"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Geist"
    }
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "fontawesome"
  },
  "redirects": [
    {
      "source": "/metadata",
      "destination": "/storage"
    },
    {
      "source": "/react",
      "destination": "/react/get-started"
    },
    {
      "source": "/react/reading-and-writing",
      "destination": "/react/fetching-and-mutations"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Connections",
            "icon": "plug",
            "pages": [
              "connections",
              "connections/connecting",
              "connections/managing"
            ]
          },
          {
            "group": "Media",
            "icon": "image",
            "pages": [
